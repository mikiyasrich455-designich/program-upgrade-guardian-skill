# Program Upgrade Guardian — Environment Variables
# Copy this file to .env and fill in your values

# Program
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Authority
BUFFER_AUTHORITY=YourBufferAuthorityPubkeyHere
SQUADS_AUTHORITY=YourSquadsAuthorityPubkeyHere
SQUADS_VAULT_PUBKEY=YourSquadsVaultPubkeyHere

# Cluster
CLUSTER=mainnet-beta

# Keypair
KEYPAIR=~/.config/solana/id.json

# RPC
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Monitoring
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
